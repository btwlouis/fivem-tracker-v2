generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ServerHistory {
  id         Int      @id @default(autoincrement())
  server_id  String

  clients    Int
  timestamp  DateTime @default(now())

  server     Server   @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "FK_server_history_servers")

  @@index([timestamp], map: "timestamp")
}

model Server {
  id                 String          @id
  detailsLevel       Int?
  locale             String
  localeCountry      String
  hostname           String?
  joinId             String?
  historicalAddress  String?
  historicalIconURL  String?
  connectEndPoints   String?
  rawVariables       String?
  variables          String?
  projectName        String?
  projectDescription String
  upvotePower        Int?
  burstPower         Int?
  offline            Boolean?
  mapname            String?
  gametype           String?
  gamename           String?
  licenseKeyToken    String?
  fallback           String?
  private            Boolean?
  scriptHookAllowed  Boolean?
  enforceGameBuild   String?
  pureLevel          String?
  premium            String?
  bannerConnecting   String?
  bannerDetail       String?
  canReview          Boolean?
  ownerID            String?
  ownerName          String?
  ownerAvatar        String?
  ownerProfile       String?
  activitypubFeed    String?
  onesyncEnabled     Boolean?
  server             String?
  supportStatus      String?
  playersMax         Int?
  playersCurrent     Int?
  iconVersion        Int?
  tags               String?
  resources          String?
  players            String?
  updated_at         DateTime        @updatedAt
  created_at         DateTime        @default(now())

  server_history     ServerHistory[]

  @@index([localeCountry, playersCurrent])
  @@index([playersCurrent])
  @@index([updated_at])
}
